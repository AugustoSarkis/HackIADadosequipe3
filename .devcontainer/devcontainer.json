{
  "name": "🚀 Ambiente de Dados e IA (Python 3.11)",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "App.py"
      ]
    },
    "vscode": {
      "settings": {
        "workbench.colorTheme": "One Dark Pro",
        "workbench.iconTheme": "material-icon-theme",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-python.black-formatter",
        "python.analysis.typeCheckingMode": "basic",
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "zhuangtongfa.Material-theme",
        "PKief.material-icon-theme",
        "eamodio.gitlens",
        "tamasfe.even-better-toml",
        "ms-vsliveshare.vsliveshare"
      ]
    }
  },
  "updateContentCommand": "[ -f packages.txt ] && sudo apt update && sudo apt upgrade -y && sudo xargs apt install -y <packages.txt || true; [ -f requirements.txt ] && pip3 install --user -r requirements.txt; pip3 install --user streamlit; echo '✅ Pacotes e dependências instalados com sucesso!'",
  "postAttachCommand": {
    "server": "streamlit run App.py --server.enableCORS false --server.enableXsrfProtection false"
  },
  "portsAttributes": {
    "8501": {
      "label": "🌟 Aplicação Streamlit",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    8501
  ]
}